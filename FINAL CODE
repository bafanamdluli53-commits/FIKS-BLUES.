                totalProfit += pnl;
            } else {
                losses++;
                totalLoss += Math.abs(pnl);
            }
        }

        const totalTrades = wins + losses;
        const winRate = totalTrades > 0 ? (wins / totalTrades) * 100 : 0;
        const totalReturn = ((equity - 10000) / 10000) * 100;
        const profitFactor = totalLoss > 0 ? totalProfit / totalLoss : 0;

        document.getElementById('totalReturn').textContent = totalReturn.toFixed(1) + '%';
        document.getElementById('totalReturn').style.color = totalReturn >= 0 ? 'var(--accent-green)' : 'var(--accent-red)';
