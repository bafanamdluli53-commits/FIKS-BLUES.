    processData(data) {
        if (!data || data.length === 0) return;

        const latest = data[data.length - 1];
        const prev = data[data.length - 2] || latest;

        // Price Stats
        const priceChange = prev.close !== 0 ? ((latest.close - prev.close) / prev.close) * 100 : 0;
        document.getElementById('currentPrice').textContent = '$' + latest.close.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
        const priceChangeEl = document.getElementById('priceChange');
        priceChangeEl.innerHTML = `<i class="fas fa-${priceChange >= 0 ? 'arrow-up' : 'arrow-down'}"></i> ${priceChange >= 0 ? '+' : ''}${priceChange.toFixed(2)}%`;
        priceChangeEl.className = `stat-change ${priceChange >= 0 ? 'positive' : 'negative'}`;
        document.getElementById('priceCard').className = `stat-card ${priceChange >= 0 ? 'bullish' : 'bearish'}`;

        // RSI
        const rsi = this.calculateRSI(data);
        const latestRSI = rsi[rsi.length - 1] || 50;
        document.getElementById('rsiValue').textContent = latestRSI.toFixed(1);

        let rsiSignal = 'Neutral';
        let rsiClass = 'neutral';
        if (latestRSI > this.settings.rsiOverbought) {
            rsiSignal = 'Overbought';
            rsiClass = 'bearish';
        } else if (latestRSI < this.settings.rsiOversold) {
            rsiSignal = 'Oversold';
            rsiClass = 'bullish';
        }
        document.getElementById('rsiSignal').textContent = rsiSignal;
        document.getElementById('rsiSignal').className = `stat-change ${rsiClass === 'bullish' ? 'positive' : rsiClass === 'bearish' ? 'negative' : ''}`;
        document.getElementById('rsiCard').className = `stat-card ${rsiClass}`;
        document.getElementById('rsiMeter').style.width = latestRSI + '%';
        document.getElementById('rsiMeter').className = `confidence-fill ${latestRSI > 70 || latestRSI < 30 ? 'high' : 'medium'}`;

        // MACD
        const macd = this.calculateMACD(data);
        const latestMACD = macd.macdLine[macd.macdLine.length - 1] || 0;
        const latestSignal = macd.signalLine[macd.signalLine.length - 1] || 0;
        document.getElementById('macdValue').textContent = latestMACD.toFixed(3);

        let macdSignalText = 'Neutral';
        let macdClass = 'neutral';
        if (latestMACD > latestSignal) {
            macdSignalText = 'Bullish';
            macdClass = 'bullish';
        } else if (latestMACD < latestSignal) {
            macdSignalText = 'Bearish';
            macdClass = 'bearish';
        }
        document.getElementById('macdSignal').textContent = macdSignalText;
        document.getElementById('macdSignal').className = `stat-change ${macdClass === 'bullish' ? 'positive' : macdClass === 'bearish' ? 'negative' : ''}`;
        document.getElementById('macdCard').className = `stat-card ${macdClass}`;

        // Trend
        const ema20 = this.calculateEMA(data, 20);
        const ema50 = this.calculateEMA(data, 50);
        const latestEMA20 = ema20[ema20.length - 1] || latest.close;
        const latestEMA50 = ema50[ema50.length - 1] || latest.close;

        let trend = 'Neutral';
        let trendClass = 'neutral';
        let trendStrength = 50;

        if (latest.close > latestEMA20 && latestEMA20 > latestEMA50) {
            trend = 'Strong Uptrend';
            trendClass = 'bullish';
            trendStrength = 85;
        } else if (latest.close > latestEMA20) {
            trend = 'Uptrend';
            trendClass = 'bullish';
            trendStrength = 65;
        } else if (latest.close < latestEMA20 && latestEMA20 < latestEMA50) {
            trend = 'Strong Downtrend';
            trendClass = 'bearish';
            trendStrength = 85;
        } else if (latest.close < latestEMA20) {
            trend = 'Downtrend';
            trendClass = 'bearish';
            trendStrength = 65;
        }

        document.getElementById('trendValue').textContent = trend;
        document.getElementById('trendStrength').textContent = trendStrength + '% Strength';
        document.getElementById('trendStrength').className = `stat-change ${trendClass === 'bullish' ? 'positive' : trendClass === 'bearish' ? 'negative' : ''}`;
        document.getElementById('trendCard').className = `stat-card ${trendClass}`;
        document.getElementById('trendMeter').style.width = trendStrength + '%';
        document.getElementById('trendMeter').className = `confidence-fill ${trendStrength > 70 ? 'high' : trendStrength > 40 ? 'medium' : 'low'}`;

        // Volume
        const avgVolume = data.slice(-20).reduce((sum, d) => sum + d.volume, 0) / 20;
        const volumeRatio = avgVolume > 0 ? latest.volume / avgVolume : 1;
        document.getElementById('volumeValue').textContent = this.formatVolume(latest.volume);

        let volumeSignal = 'Normal';
        if (volumeRatio > 2) volumeSignal = 'High';
        else if (volumeRatio < 0.5) volumeSignal = 'Low';
        document.getElementById('volumeSignal').textContent = volumeSignal;
        document.getElementById('volumeCard').className = `stat-card ${volumeRatio > 1.5 ? 'info' : 'neutral'}`;

        // ATR
        const atr = this.calculateATR(data);
        const latestATR = atr[atr.length - 1] || latest.close * 0.02;
        document.getElementById('atrValue').textContent = latestATR.toFixed(2);

        const atrPercent = (latestATR / latest.close) * 100;
        let volatility = 'Low';
        if (atrPercent > 3) volatility = 'Very High';
        else if (atrPercent > 2) volatility = 'High';
        else if (atrPercent > 1) volatility = 'Medium';
        document.getElementById('atrSignal').textContent = volatility;

        // Update Charts
        this.updateCharts(data, rsi, macd);

        // Generate Signals
        const signals = this.generateSignals(data);
        this.displaySignals(signals);
        this.calculateEntries(data, signals);
        this.updateAIPrediction(data, signals, trend, latestRSI);
        this.runBacktest(data, signals);
    },

    formatVolume(volume) {
        if (volume >= 1e9) return (volume / 1e9).toFixed(2) + 'B';
        if (volume >= 1e6) return (volume / 1e6).toFixed(2) + 'M';
        if (volume >= 1e3) return (volume / 1e3).toFixed(2) + 'K';
        return volume.toFixed(0);
    },

