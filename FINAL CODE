    calculateEntries(data, signals) {
        const tbody = document.getElementById('entryTableBody');
        tbody.innerHTML = '';

        const latest = data[data.length - 1];
        const atr = this.calculateATR(data);
        const currentATR = atr[atr.length - 1] || latest.close * 0.02;
        const rsi = this.calculateRSI(data);
        const latestRSI = rsi[rsi.length - 1] || 50;

        const entries = [];

        // Long Entry
        const supportLevel = Math.min(...data.slice(-20).map(d => d.low));
        const longEntry = Math.max(supportLevel * 1.002, latest.close - currentATR * 0.3);
        const longSL = longEntry - currentATR * 1.5;
        const longTP = longEntry + currentATR * 3;
        const longRR = longEntry > longSL ? ((longTP - longEntry) / (longEntry - longSL)).toFixed(1) : '0.0';

        let longConfidence = 50;
        if (latestRSI < 35) longConfidence += 25;
        if (latest.close > (this.calculateEMA(data, 20)[this.calculateEMA(data, 20).length - 1] || 0)) longConfidence += 15;
        if (latest.volume > (data.slice(-20).reduce((a, b) => a + b.volume, 0) / 20)) longConfidence += 10;

        entries.push({
            direction: 'long',
            entry: longEntry,
            sl: longSL,
            tp: longTP,
            rr: longRR,
            confidence: Math.min(longConfidence, 95)
        });

        // Short Entry
        const resistanceLevel = Math.max(...data.slice(-20).map(d => d.high));
        const shortEntry = Math.min(resistanceLevel * 0.998, latest.close + currentATR * 0.3);
        const shortSL = shortEntry + currentATR * 1.5;
        const shortTP = shortEntry - currentATR * 3;
        const shortRR = shortSL > shortEntry ? ((shortEntry - shortTP) / (shortSL - shortEntry)).toFixed(1) : '0.0';

        let shortConfidence = 50;
        if (latestRSI > 65) shortConfidence += 25;
        if (latest.close < (this.calculateEMA(data, 20)[this.calculateEMA(data, 20).length - 1] || Infinity)) shortConfidence += 15;
        if (latest.volume > (data.slice(-20).reduce((a, b) => a + b.volume, 0) / 20)) shortConfidence += 10;

        entries.push({
            direction: 'short',
            entry: shortEntry,
            sl: shortSL,
            tp: shortTP,
            rr: shortRR,
            confidence: Math.min(shortConfidence, 95)
        });

        // Sort by confidence
        entries.sort((a, b) => b.confidence - a.confidence);

        entries.forEach(entry => {
            const row = document.createElement('tr');
            row.innerHTML = `
                <td><span class="direction-badge ${entry.direction}">${entry.direction.toUpperCase()}</span></td>
                <td>$${entry.entry.toFixed(2)}</td>
                <td>$${entry.sl.toFixed(2)}</td>
                <td>$${entry.tp.toFixed(2)}</td>
                <td><strong>${entry.confidence}%</strong></td>
            `;
            tbody.appendChild(row);
        });
    },

    updateAIPrediction(data, signals, trend, rsi) {
        const latest = data[data.length - 1];
        const prev = data[data.length - 2] || latest;

        let bullishScore = 0;
        let bearishScore = 0;
        let reasons = [];

        // RSI Analysis
        if (rsi < 30) {
            bullishScore += 2;
            reasons.push('RSI oversold');
        } else if (rsi > 70) {
            bearishScore += 2;
            reasons.push('RSI overbought');
        }

        // Trend Analysis
        if (trend.includes('Uptrend')) {
            bullishScore += 2;
            reasons.push('Uptrend intact');
        } else if (trend.includes('Downtrend')) {
            bearishScore += 2;
            reasons.push('Downtrend active');
        }

        // MACD
        const macd = this.calculateMACD(data);
        const latestMACD = macd.macdLine[macd.macdLine.length - 1] || 0;
        const latestSignal = macd.signalLine[macd.signalLine.length - 1] || 0;

        if (latestMACD > latestSignal) {
            bullishScore += 1;
            reasons.push('MACD bullish');
        } else {
            bearishScore += 1;
            reasons.push('MACD bearish');
        }

        // Volume
        const avgVolume = data.slice(-20).reduce((sum, d) => sum + d.volume, 0) / 20;
        if (avgVolume > 0 && latest.volume > avgVolume * 1.5) {
            if (latest.close > prev.close) {
                bullishScore += 1;
                reasons.push('Volume rising');
            } else {
                bearishScore += 1;
                reasons.push('Volume falling');
            }
        }

        // Recent Signals
        const recentSignals = signals.slice(-3);
        const buySignals = recentSignals.filter(s => s.type === 'buy').length;
        const sellSignals = recentSignals.filter(s => s.type === 'sell').length;

        if (buySignals > sellSignals) {
            bullishScore += buySignals;
            reasons.push(`${buySignals} buy signals`);
        } else if (sellSignals > buySignals) {
            bearishScore += sellSignals;
            reasons.push(`${sellSignals} sell signals`);
        }

        // Determine Prediction
        let prediction = 'neutral';
        let confidence = 50;

        if (bullishScore > bearishScore) {
            prediction = 'bullish';
            confidence = 50 + (bullishScore - bearishScore) * 8;
        } else if (bearishScore > bullishScore) {
            prediction = 'bearish';
            confidence = 50 + (bearishScore - bullishScore) * 8;
        }

        confidence = Math.min(confidence, 95);

        // Update UI
        const emoji = prediction === 'bullish' ? '🚀' : prediction === 'bearish' ? '🔻' : '➖';
        const text = prediction === 'bullish' ? 'BULLISH' : prediction === 'bearish' ? 'BEARISH' : 'NEUTRAL';
