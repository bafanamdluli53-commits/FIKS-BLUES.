    // ============================================
    // TECHNICAL INDICATORS
    // ============================================

    calculateRSI(data, period = 14) {
        if (data.length < period + 1) return [];
        const closes = data.map(d => d.close);
        const rsi = [];
        let gains = 0, losses = 0;

        for (let i = 1; i <= period; i++) {
            const change = closes[i] - closes[i-1];
            if (change > 0) gains += change;
            else losses -= change;
        }

        let avgGain = gains / period;
        let avgLoss = losses / period;

        for (let i = period; i < closes.length; i++) {
            const change = closes[i] - closes[i-1];
            if (change > 0) {
                avgGain = (avgGain * (period - 1) + change) / period;
                avgLoss = (avgLoss * (period - 1)) / period;
            } else {
                avgGain = (avgGain * (period - 1)) / period;
                avgLoss = (avgLoss * (period - 1) - change) / period;
            }

            const rs = avgLoss === 0 ? 100 : avgGain / avgLoss;
            rsi.push(100 - (100 / (1 + rs)));
        }

        return rsi;
    },

    calculateEMA(data, period) {
        if (data.length < period) return [];
        const closes = data.map(d => d.close);
        const ema = [];
        const multiplier = 2 / (period + 1);

        let sum = 0;
        for (let i = 0; i < period; i++) {
            sum += closes[i];
        }
        ema.push(sum / period);

        for (let i = period; i < closes.length; i++) {
            ema.push((closes[i] - ema[ema.length - 1]) * multiplier + ema[ema.length - 1]);
        }

        return ema;
    },

    calculateSMA(data, period) {
        if (data.length < period) return [];
        const closes = data.map(d => d.close);
        const sma = [];

        for (let i = period - 1; i < closes.length; i++) {
            let sum = 0;
            for (let j = 0; j < period; j++) {
                sum += closes[i - j];
            }
            sma.push(sum / period);
        }

        return sma;
    },

    calculateMACD(data, fast = 12, slow = 26, signal = 9) {
        if (data.length < slow) return { macdLine: [], signalLine: [], histogram: [] };

        const emaFast = this.calculateEMA(data, fast);
        const emaSlow = this.calculateEMA(data, slow);

        const macdLine = [];
        const startIdx = slow - fast;

        for (let i = 0; i < emaSlow.length; i++) {
            macdLine.push(emaFast[i + startIdx] - emaSlow[i]);
        }

        const signalLine = [];
        const multiplier = 2 / (signal + 1);
        signalLine.push(macdLine[0]);

        for (let i = 1; i < macdLine.length; i++) {
            signalLine.push((macdLine[i] - signalLine[i-1]) * multiplier + signalLine[i-1]);
        }

        const histogram = [];
        for (let i = 0; i < signalLine.length; i++) {
            histogram.push(macdLine[i] - signalLine[i]);
        }

        return { macdLine, signalLine, histogram };
    },

    calculateBollingerBands(data, period = 20, stdDev = 2) {
        if (data.length < period) return { upper: [], middle: [], lower: [] };

        const closes = data.map(d => d.close);
        const sma = this.calculateSMA(data, period);
        const upper = [];
        const lower = [];

        for (let i = period - 1; i < closes.length; i++) {
            let sum = 0;
            for (let j = 0; j < period; j++) {
                sum += Math.pow(closes[i - j] - sma[i - period + 1], 2);
            }
            const std = Math.sqrt(sum / period);
            upper.push(sma[i - period + 1] + stdDev * std);
            lower.push(sma[i - period + 1] - stdDev * std);
        }

        return { upper, middle: sma, lower };
    },

    calculateATR(data, period = 14) {
        if (data.length < period + 1) return [];
        const atr = [];
        const trueRanges = [];

        for (let i = 1; i < data.length; i++) {
            const high = data[i].high;
            const low = data[i].low;
            const prevClose = data[i-1].close;

            const tr1 = high - low;
            const tr2 = Math.abs(high - prevClose);
            const tr3 = Math.abs(low - prevClose);

            trueRanges.push(Math.max(tr1, tr2, tr3));
        }

        let atrValue = trueRanges.slice(0, period).reduce((a, b) => a + b, 0) / period;
        atr.push(atrValue);

        for (let i = period; i < trueRanges.length; i++) {
            atrValue = (atrValue * (period - 1) + trueRanges[i]) / period;
            atr.push(atrValue);
        }

        return atr;
    },

    // ============================================
    // DATA GENERATION & FETCHING
    // ============================================

    generateDemoData(symbol, timeframe) {
        const data = [];
        let price = 100 + Math.random() * 90000;
        if (symbol.includes('BTC')) price = 45000 + Math.random() * 10000;
        else if (symbol.includes('ETH')) price = 3000 + Math.random() * 1000;

        const now = new Date();
        const intervals = { '1m': 1, '5m': 5, '15m': 15, '1h': 60, '4h': 240, '1d': 1440 };
        const minutes = intervals[timeframe] || 60;

        for (let i = 200; i >= 0; i--) {
            const time = new Date(now.getTime() - i * minutes * 60000);
            const volatility = 0.02;
            const trend = Math.sin(i / 30) * price * 0.05;

            const change = (Math.random() - 0.5) * volatility * price;
            price += change + (trend * 0.01);

            const open = price;
            const high = price * (1 + Math.random() * volatility * 0.5);
            const low = price * (1 - Math.random() * volatility * 0.5);
            const close = price + (Math.random() - 0.5) * volatility * price * 0.5;
            const volume = Math.floor(Math.random() * 1000000) + 100000;

            data.push({ time, open, high, low, close, volume });
            price = close;
        }

        return data;
    },

    async fetchBinanceData(symbol, timeframe) {
        const intervalMap = { '1m': '1m', '5m': '5m', '15m': '15m', '1h': '1h', '4h': '4h', '1d': '1d' };
        const interval = intervalMap[timeframe] || '1h';
        const cleanSymbol = symbol.replace(/[^a-zA-Z0-9]/g, '');

        try {
            const response = await fetch(`https://api.binance.com/api/v3/klines?symbol=${cleanSymbol}&interval=${interval}&limit=200`);

            if (!response.ok) throw new Error('API Error');

            const rawData = await response.json();
            return rawData.map(d => ({
                time: new Date(d[0]),
                open: parseFloat(d[1]),
                high: parseFloat(d[2]),
                low: parseFloat(d[3]),
                close: parseFloat(d[4]),
                volume: parseFloat(d[5])
            }));
        } catch (error) {
            throw error;
        }
    },

    // ============================================
    // SIGNAL GENERATION
    // ============================================

    generateSignals(data) {
        const signals = [];
        const rsi = this.calculateRSI(data, this.settings.rsiPeriod);
        const macd = this.calculateMACD(data, this.settings.emaFast, this.settings.emaSlow);
        const bb = this.calculateBollingerBands(data);
        const emaFast = this.calculateEMA(data, this.settings.emaFast);
        const emaSlow = this.calculateEMA(data, this.settings.emaSlow);
        const atr = this.calculateATR(data);

        const offset = data.length - rsi.length;

        for (let i = 20; i < data.length; i++) {
            const rsiIdx = i - offset;
            if (rsiIdx < 0 || rsiIdx >= rsi.length) continue;

            let signal = null;
            let reasons = [];
            let confidence = 0;

            const currentPrice = data[i].close;
            const currentRSI = rsi[rsiIdx];
            const currentATR = atr[Math.min(i - 1, atr.length - 1)] || currentPrice * 0.02;

            // RSI Analysis
            if (currentRSI < this.settings.rsiOversold) {
                reasons.push('RSI Oversold');
                confidence += 25;
            } else if (currentRSI > this.settings.rsiOverbought) {
                reasons.push('RSI Overbought');
                confidence += 25;
            }

            // MACD Analysis
            const macdIdx = i - (data.length - macd.macdLine.length);
            if (macdIdx > 0 && macdIdx < macd.macdLine.length) {
                if (macd.macdLine[macdIdx] > macd.signalLine[macdIdx] && 
                    macd.macdLine[macdIdx-1] <= macd.signalLine[macdIdx-1]) {
                    reasons.push('MACD Bullish Cross');
                    confidence += 25;
                } else if (macd.macdLine[macdIdx] < macd.signalLine[macdIdx] && 
                           macd.macdLine[macdIdx-1] >= macd.signalLine[macdIdx-1]) {
                    reasons.push('MACD Bearish Cross');
                    confidence += 25;
                }
            }

            // EMA Analysis
            const emaIdx = i - (data.length - emaFast.length);
            if (emaIdx > 0 && emaIdx < emaFast.length) {
                if (emaFast[emaIdx] > emaSlow[emaIdx] && emaFast[emaIdx-1] <= emaSlow[emaIdx-1]) {
                    reasons.push('EMA Golden Cross');
                    confidence += 20;
                } else if (emaFast[emaIdx] < emaSlow[emaIdx] && emaFast[emaIdx-1] >= emaSlow[emaIdx-1]) {
                    reasons.push('EMA Death Cross');
                    confidence += 20;
                }
            }

            // Bollinger Bands
            const bbIdx = i - (data.length - bb.lower.length);
            if (bbIdx >= 0 && bbIdx < bb.lower.length) {
                if (currentPrice <= bb.lower[bbIdx]) {
                    reasons.push('Below Lower Band');
                    confidence += 15;
                } else if (currentPrice >= bb.upper[bbIdx]) {
                    reasons.push('Above Upper Band');
                    confidence += 15;
                }
            }

            // Determine signal
            if (confidence >= 60) {
                const bullishCount = reasons.filter(r => 
                    r.includes('Oversold') || r.includes('Bullish') || r.includes('Golden') || r.includes('Below')
                ).length;

                const bearishCount = reasons.filter(r => 
                    r.includes('Overbought') || r.includes('Bearish') || r.includes('Death') || r.includes('Above')
                ).length;

                if (bullishCount > bearishCount) signal = 'buy';
                else if (bearishCount > bullishCount) signal = 'sell';
            }

            if (signal) {
                const sl = currentATR * 2;
                const tp = currentATR * 3;

                signals.push({
                    time: data[i].time,
                    type: signal,
                    price: currentPrice,
                    reasons: reasons,
                    confidence: Math.min(confidence, 100),
                    stopLoss: signal === 'buy' ? currentPrice - sl : currentPrice + sl,
                    takeProfit: signal === 'buy' ? currentPrice + tp : currentPrice - tp,
                    atr: currentATR
                });
            }
        }

        return signals;
    },

