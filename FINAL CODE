        let equity = 10000;
        const equityCurve = [equity];
        let wins = 0;
        let losses = 0;
        let totalProfit = 0;
        let totalLoss = 0;

        for (let i = 0; i < signals.length - 1; i++) {
            const signal = signals[i];
            const nextSignal = signals[i + 1];

            const entryPrice = signal.price;
            const exitPrice = nextSignal.price;
            const direction = signal.type === 'buy' ? 1 : -1;

            const pnl = ((exitPrice - entryPrice) / entryPrice) * 100 * direction;

            const tradeSize = equity * 0.02;
            const tradePnl = tradeSize * (pnl / 100);

            equity += tradePnl;
            equityCurve.push(equity);

